# Copier ce fichier en .env puis renseigner les valeurs (ne pas committer .env).
# Lagoon Padel — API PHP

# Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lagoon_padel
DB_USER=root
DB_PASS=

# JWT — utiliser une chaîne longue et aléatoire en production
LAGOON_JWT_SECRET=change-me-in-production-use-long-random-string
# Durée de validité du token en secondes (604800 = 7 jours)
LAGOON_JWT_TTL=604800

# CORS : origine autorisée pour l’app web / Flutter (ex. https://app.example.com) ; * en dev local
CORS_ORIGIN=*

# Prix d’un créneau (XPF, sans décimales)
LAGOON_PRICE_PER_SLOT_XPF=5000

# ——— OSB Lyra — https://secure.osb.pf/doc/fr-FR/ ———
# Onglet « Clés d’API REST » du back-office marchand OSB :
#   • Utilisateur → PAYZEN_SHOP_ID
#   • Mot de passe de test / de production → PAYZEN_API_KEY_TEST / PAYZEN_API_KEY_PROD
#     (longue chaîne du type testpassword_… / prodpassword_… — pas une autre clé courte)
#   • Clé publique de test / prod (section JavaScript) → PAYZEN_PUBLIC_KEY en mode correspondant
#   • Clé HMAC-SHA-256 test / prod (section kr-hash) → PAYZEN_HMAC_KEY_* ; alors PAYZEN_SIGN_ALGORITHM=sha256
PAYZEN_MODE=test
PAYZEN_SHOP_ID=
PAYZEN_API_KEY_TEST=
PAYZEN_API_KEY_PROD=

# Si vous ne distinguez pas test/prod dans le fichier (ex. un seul environnement), une seule ligne suffit :
# PAYZEN_API_KEY=

# OBLIGATOIRE : « Clé publique de test » ou « de production » (ligne complète boutique:testpublickey_… ou publickey_…).
PAYZEN_PUBLIC_KEY=

# Section « kr-hash » du même écran — reprenez la clé HMAC-SHA-256 test ou prod affichée par OSB.
PAYZEN_HMAC_KEY_TEST=
PAYZEN_HMAC_KEY_PROD=
# Ou une seule clé pour les deux : PAYZEN_HMAC_KEY=

# Avec les clés « HMAC-SHA-256 » OSB : sha256. (sha1 seulement si votre BO impose explicitement SHA-1.)
PAYZEN_SIGN_ALGORITHM=sha256

# URL API indiquée par OSB (Lyra Collect régional). Alternative internationale : api.lyra.com
PAYZEN_REST_CREATE_PAYMENT_URL=https://api.secure.osb.pf/api-payment/V4/Charge/CreatePayment
PAYZEN_PAYMENT_PAGE_URL=https://secure.osb.pf/vads-payment/
PAYZEN_PENDING_TTL_MINUTES=30

# Surcharges rares (identifiants REST différents de « identifiant boutique », etc.) :
# PAYZEN_REST_USERNAME=
# PAYZEN_REST_PASSWORD=

# Notification instantanée dans le BO : https://VOTRE-API/api/payment/payzen/ipn
