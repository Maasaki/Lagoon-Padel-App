# Copier ce fichier en .env puis renseigner les valeurs (ne pas committer .env).
# Lagoon Padel — API PHP

# Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lagoon_padel
DB_USER=root
DB_PASS=

# JWT — utiliser une chaîne longue et aléatoire en production
LAGOON_JWT_SECRET=change-me-in-production-use-long-random-string
# Durée de validité du token en secondes (604800 = 7 jours)
LAGOON_JWT_TTL=604800

# CORS : origine autorisée pour l’app web / Flutter (ex. https://app.example.com) ; * en dev local
CORS_ORIGIN=*
